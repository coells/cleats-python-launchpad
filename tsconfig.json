{
    "compilerOptions": {
        "target": "ES2022",
        "module": "Node16",
        "moduleResolution": "Node16",
        "lib": ["ES2022"],
        "rootDir": ".",
        "outDir": "out",
        "strict": true,
        "declaration": true,
        "sourceMap": true,
        "skipLibCheck": true,
        "esModuleInterop": true,
        "types": ["node", "vscode"]
    },
    "include": ["src/**/*.ts", "test/**/*.ts"]
}
