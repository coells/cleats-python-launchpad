            "problemMatcher": ["$tsc-watch"]
        },
        {
            "label": "npm: lint",
            "type": "npm",
            "script": "lint",
            "problemMatcher": ["$eslint-stylish"]
        },
        {
            "label": "npm: test",
            "type": "npm",
            "script": "test"
        },
        {
            "label": "npm: package",
            "type": "npm",
            "script": "package"
        }
    ]
}
